# Backend configuration
BASE_URL=https://your-domain.example
PORT=3001
NODE_ENV=production

# Deployment provenance surfaced through /health/version.
# Set APP_COMMIT_SHA from the exact git commit used for the deployed source.
APP_COMMIT_SHA=
APP_BUILD_TIME=
APP_RELEASE=

# MariaDB connection
# Development defaults use Docker Compose on 127.0.0.1:3307. Put real local
# credentials in ignored .env.database.local, not in this file.
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3307
MARIADB_DATABASE=social_insights_dev
MARIADB_TEST_DATABASE=social_insights_test
MARIADB_USER=social_insights
MARIADB_PASSWORD=replace_with_local_password
MARIADB_ROOT_PASSWORD=replace_with_local_root_password
DATABASE_URL=mariadb://social_insights:replace_with_local_password@127.0.0.1:3307/social_insights_dev
DATABASE_TEST_URL=mariadb://social_insights:replace_with_local_password@127.0.0.1:3307/social_insights_test

# TikTok OAuth credentials
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://your-domain.example/api/integrations/tiktok/callback
TIKTOK_VIDEO_PAGE_SIZE=20
TIKTOK_MAX_VIDEO_PAGES=20

# YouTube OAuth and bounded read-only sync. Disabled unless explicitly enabled.
YOUTUBE_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://your-domain.example/api/integrations/youtube/callback
YOUTUBE_REQUEST_TIMEOUT_MS=10000
YOUTUBE_OAUTH_STATE_TTL_SECONDS=600
YOUTUBE_SYNC_MAX_PLAYLIST_PAGES=5
# Keep this in 50-video API batches (50-1000); non-multiples round down.
YOUTUBE_SYNC_MAX_VIDEOS=250
YOUTUBE_SYNC_MAX_RETRIES=2
YOUTUBE_SYNC_TIME_BUDGET_SECONDS=180
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=180
YOUTUBE_ANALYTICS_TOP_VIDEOS=200

# Google Analytics 4 uses a dedicated Google OAuth client and grant. It must
# differ from both Google sign-in and YouTube product authorization.
GA4_CLIENT_ID=
GA4_CLIENT_SECRET=
GA4_REDIRECT_URI=https://your-domain.example/api/integrations/google-analytics/callback
GA4_REQUEST_TIMEOUT_MS=10000
GA4_OAUTH_STATE_TTL_SECONDS=600
GA4_SYNC_MAX_RETRIES=2
GA4_SYNC_TIME_BUDGET_SECONDS=180
GA4_ANALYTICS_LOOKBACK_DAYS=180
GA4_SYNC_MAX_DIMENSION_ROWS=100
GA4_DISCOVERY_MAX_PAGES=10
GA4_DISCOVERY_MAX_PROPERTIES=100

# Meta Facebook Login for Business. Both products are disabled unless their
# feature flag is enabled and the operator asserts the exact approved scope set.
META_APP_ID=
META_APP_SECRET=
META_FACEBOOK_LOGIN_CONFIG_ID=
META_INSTAGRAM_LOGIN_CONFIG_ID=
META_GRAPH_API_VERSION=v25.0
FACEBOOK_REDIRECT_URI=https://your-domain.example/api/integrations/facebook/callback
INSTAGRAM_REDIRECT_URI=https://your-domain.example/api/integrations/instagram/callback
META_FACEBOOK_APPROVED_SCOPES=pages_show_list,pages_read_engagement,read_insights
META_INSTAGRAM_APPROVED_SCOPES=instagram_basic,instagram_manage_insights,pages_show_list,pages_read_engagement
META_REQUEST_TIMEOUT_MS=10000
META_OAUTH_STATE_TTL_SECONDS=600
META_SYNC_MAX_RETRIES=2
META_SYNC_TIME_BUDGET_SECONDS=180
META_INSIGHTS_LOOKBACK_DAYS=90
META_SYNC_MAX_CONTENT_ITEMS=100
META_SYNC_MAX_CONTENT_PAGES=5
META_USAGE_DELAY_PERCENT=80

# Provider feature gates. TikTok is enabled unless explicitly set to 0.
# Meta providers remain disabled until their exact runtime and review settings are ready.
FEATURE_TIKTOK_CONNECTOR=1
FEATURE_INSTAGRAM_CONNECTOR=0
FEATURE_FACEBOOK_PAGES_CONNECTOR=0
FEATURE_GA4_CONNECTOR=0

# Backend token signing
BACKEND_JWT_SECRET=replace_with_64_char_random_hex

# Token encryption key (32 bytes, hex or base64)
ENCRYPTION_KEY=replace_with_32_byte_base64_or_hex
ENCRYPTION_KEY_VERSION=local-v1
ENCRYPTION_PREVIOUS_KEYS=

# Authentication providers
AUTH_DEV_MAGIC_LINKS=false
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
MAIL_ADAPTER=development
MAIL_FROM=support@example.com

# Sessions, sync and worker bounds
SESSION_TTL_SECONDS=2592000
SESSION_IDLE_SECONDS=604800
SYNC_INTERVAL_SECONDS=21600
SYNC_STAGGER_SECONDS=900
SYNC_LEASE_SECONDS=300
SYNC_RETRY_BASE_SECONDS=60
SYNC_RETRY_MAX_SECONDS=3600
MANUAL_SYNC_COOLDOWN_SECONDS=900
WORKER_TIME_BUDGET_SECONDS=240
WORKER_OVERDUE_SECONDS=1800
DASHBOARD_MAX_RANGE_DAYS=366

# Asynchronous PDF reports. Production artifacts must live in a private,
# writable directory outside public_html and every application public root.
FEATURE_PDF_REPORTS=false
REPORT_ARTIFACT_ROOT=/home/YOUR_CPANEL_USER/secure/social-insights/report-artifacts
REPORT_DOWNLOAD_GRANT_TTL_SECONDS=120
REPORT_LEASE_SECONDS=300
REPORT_MAX_ATTEMPTS=3
REPORT_MAX_RESOURCES=20
REPORT_MAX_RANGE_DAYS=366
REPORT_MAX_SNAPSHOT_BYTES=2097152
REPORT_MAX_ARTIFACT_BYTES=20971520
REPORT_MAX_PAGES=80
REPORT_MAX_CONTENT_ROWS_PER_RESOURCE=30

# Retention gates
LONG_TERM_RETENTION_ENABLED=false
RETENTION_POLICY_VERSION=unapproved-local

# Optional: Looker Studio OAuth client identifiers
LOOKER_CLIENT_ID=looker-studio-connector
# Leave LOOKER_CLIENT_SECRET blank/omitted for the legacy Apps Script public client.
# If set, use a real random secret and configure the connector to send it.
LOOKER_CLIENT_SECRET=
# Exact Apps Script OAuth callback URLs accepted by /oauth/authorize.
# Use the value returned by OAuth2 service.getRedirectUri(); no query/fragment is allowed.
LOOKER_REDIRECT_URIS=https://script.google.com/macros/d/YOUR_SCRIPT_ID/usercallback

# Token store paths (must be outside public web root)
TOKEN_STORE_PATH=/home/YOUR_CPANEL_USER/secure/social-insights/tokens.json
TOKEN_LOCK_PATH=/home/YOUR_CPANEL_USER/secure/social-insights/tokens.json.lock
TOKEN_PRUNE_DAYS=30
STATE_STORE_PATH=/home/YOUR_CPANEL_USER/secure/social-insights/oauth-state.json
STATE_LOCK_PATH=/home/YOUR_CPANEL_USER/secure/social-insights/oauth-state.json.lock

# Provider HTTP timeout
PROVIDER_HTTP_TIMEOUT_MS=10000

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MINUTES=5
API_RATE_LIMIT_MAX=120

# CORS (comma-separated list of allowed origins, leave blank for server-to-server only)
ALLOWED_ORIGINS=

# Proxy trust for Passenger/reverse proxies
TRUST_PROXY=1
