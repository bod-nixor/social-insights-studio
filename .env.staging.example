# Sanitized cPanel staging example for Social Insights Studio.
# Copy values into cPanel's Node.js environment UI or an untracked .env file.
# Do not commit real secrets.

# Runtime
NODE_ENV=production
BASE_URL=https://lstc.nixorcorporate.com
PORT=3001
TRUST_PROXY=2
ALLOWED_ORIGINS=https://lstc.nixorcorporate.com

# Deployment provenance. Inject APP_COMMIT_SHA from the exact source commit
# used for the Passenger deployment; build time/release are optional metadata.
APP_COMMIT_SHA=REPLACE_WITH_DEPLOYED_GIT_SHA
APP_BUILD_TIME=
APP_RELEASE=staging-YYYY-MM-DD

# cPanel MariaDB. Use a private cPanel database/user; do not expose MariaDB publicly.
DATABASE_URL=mariadb://CPANEL_DB_USER:REPLACE_WITH_STAGING_DB_PASSWORD@localhost/CPANEL_DB_NAME
DATABASE_TEST_URL=

# Sessions
SESSION_TTL_SECONDS=2592000
SESSION_IDLE_SECONDS=604800

# Public staging auth must not use development tokens.
AUTH_DEV_MAGIC_LINKS=false

# Google OIDC settings, if enabled for staging.
GOOGLE_OIDC_CLIENT_ID=REPLACE_WITH_GOOGLE_STAGING_CLIENT_ID
GOOGLE_OIDC_CLIENT_SECRET=REPLACE_WITH_GOOGLE_STAGING_CLIENT_SECRET

# Real mail adapter for magic-link sign-in.
MAIL_ADAPTER=smtp
MAIL_FROM=Social Insights Studio <no-reply@lstc.nixorcorporate.com>
MAIL_SUBJECT=Your Social Insights Studio sign-in code
SMTP_HOST=mail.lstc.nixorcorporate.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=true
SMTP_USER=no-reply@lstc.nixorcorporate.com
SMTP_PASSWORD=REPLACE_WITH_STAGING_SMTP_PASSWORD
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# TikTok Sandbox OAuth credentials.
TIKTOK_CLIENT_KEY=REPLACE_WITH_TIKTOK_SANDBOX_CLIENT_KEY
TIKTOK_CLIENT_SECRET=REPLACE_WITH_TIKTOK_SANDBOX_CLIENT_SECRET
TIKTOK_REDIRECT_URI=https://lstc.nixorcorporate.com/api/integrations/tiktok/callback
TIKTOK_VIDEO_PAGE_SIZE=20
TIKTOK_MAX_VIDEO_PAGES=20
PROVIDER_HTTP_TIMEOUT_MS=10000

# YouTube remains disabled until Google OAuth configuration and review evidence
# are ready. The redirect must exactly match BASE_URL plus this callback path.
YOUTUBE_ENABLED=false
YOUTUBE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID
YOUTUBE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET
YOUTUBE_REDIRECT_URI=https://lstc.nixorcorporate.com/api/integrations/youtube/callback
YOUTUBE_REQUEST_TIMEOUT_MS=10000
YOUTUBE_OAUTH_STATE_TTL_SECONDS=600
YOUTUBE_SYNC_MAX_PLAYLIST_PAGES=5
# Keep this in 50-video API batches (50-1000); non-multiples round down.
YOUTUBE_SYNC_MAX_VIDEOS=250
YOUTUBE_SYNC_MAX_RETRIES=2
YOUTUBE_SYNC_TIME_BUDGET_SECONDS=180
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=180
YOUTUBE_ANALYTICS_TOP_VIDEOS=200

# Provider feature gates. Do not enable unfinished providers in staging unless
# the full vertical slice and provider-review evidence are being tested.
FEATURE_TIKTOK_CONNECTOR=1
FEATURE_INSTAGRAM_CONNECTOR=0
FEATURE_FACEBOOK_PAGES_CONNECTOR=0
FEATURE_GA4_CONNECTOR=0

# Token encryption. Use a random 32-byte key, hex or base64. Rotate by changing
# ENCRYPTION_KEY_VERSION and moving old keys into ENCRYPTION_PREVIOUS_KEYS.
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_STAGING_HEX_OR_BASE64_KEY
ENCRYPTION_KEY_VERSION=staging-YYYY-MM-v1
ENCRYPTION_PREVIOUS_KEYS=

# Retained legacy connector signing and file stores. Keep these outside public_html.
BACKEND_JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
TOKEN_STORE_PATH=/home/CPANEL_USER/secure/social-insights-staging/tokens.json
TOKEN_LOCK_PATH=/home/CPANEL_USER/secure/social-insights-staging/tokens.json.lock
TOKEN_PRUNE_DAYS=30
STATE_STORE_PATH=/home/CPANEL_USER/secure/social-insights-staging/oauth-state.json
STATE_LOCK_PATH=/home/CPANEL_USER/secure/social-insights-staging/oauth-state.json.lock
OAUTH_STATE_TTL_MS=600000
AUTH_CODE_TTL_MS=600000

# Exact legacy Looker Studio callback allowlist. Do not use wildcards.
LOOKER_CLIENT_ID=looker-studio-connector
LOOKER_CLIENT_SECRET=
LOOKER_REDIRECT_URIS=https://script.google.com/macros/d/YOUR_SCRIPT_ID/usercallback

# Worker timing
SYNC_INTERVAL_SECONDS=21600
SYNC_STAGGER_SECONDS=900
SYNC_LEASE_SECONDS=300
SYNC_RETRY_BASE_SECONDS=60
SYNC_RETRY_MAX_SECONDS=3600
MANUAL_SYNC_COOLDOWN_SECONDS=900
WORKER_TIME_BUDGET_SECONDS=240
DASHBOARD_MAX_RANGE_DAYS=366

# Retention gates
LONG_TERM_RETENTION_ENABLED=false
RETENTION_POLICY_VERSION=unapproved-staging

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MINUTES=5
API_RATE_LIMIT_MAX=120
